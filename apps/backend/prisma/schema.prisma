generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users        User[]
  teams        Team[]
  routineTasks RoutineTask[]
  kpis         EmployeeKpi[]
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  password  String
  orgId     String
  status    String    @default("ACTIVE")
  avatarUrl      String?
  telegramChatId String?
  deletedAt      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  org       Organisation @relation(fields: [orgId], references: [id])
  userRoles    UserRole[]
  sessions     Session[]
  assignedTasks    Task[]        @relation("TaskAssignee")
  kpis             EmployeeKpi[] @relation("KpiUser")
  kpisCreated      EmployeeKpi[] @relation("KpiCreator")
  routineTasks     RoutineTask[] @relation("RoutineAssignee")
  routinesCreated  RoutineTask[] @relation("RoutineCreator")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  permissions String[]
  userRoles   UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])
  @@unique([userId, roleId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())
  org       Organisation @relation(fields: [orgId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id     String    @id @default(uuid())
  teamId String
  userId String
  leftAt DateTime?
  team   Team @relation(fields: [teamId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  deviceName   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model ActivityEvent {
  id              String   @id @default(uuid())
  eventId         String   @unique
  batchId         String
  userId          String
  orgId           String
  eventType       String
  platform        String
  url             String?
  urlHash         String?
  pageTitle       String?
  platformData    Json?
  clientTimestamp DateTime
  serverLag       Int?
  createdAt       DateTime @default(now())
  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([orgId, eventType, createdAt])
  @@index([orgId, platform, createdAt])
}

model AnalyticsHourly {
  id           String   @id @default(uuid())
  userId       String
  orgId        String
  hourBucket   DateTime
  activeSecs   Int      @default(0)
  eventCount   Int      @default(0)
  clickCount   Int      @default(0)
  keydownCount Int      @default(0)
  scrollCount  Int      @default(0)
  pageViews    Int      @default(0)
  uniqueUrls   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, hourBucket])
  @@index([orgId, hourBucket])
}

model RealtimeStatus {
  id              String    @id @default(uuid())
  userId          String    @unique
  orgId           String
  status          String    @default("OFFLINE")
  platform        String?
  lastActivityAt  DateTime?
  lastEventType   String?
  lastUrl         String?
  lastPageTitle   String?
  todayEventCount Int       @default(0)
  wentOnlineAt    DateTime?
  wentOfflineAt   DateTime?
  updatedAt       DateTime  @updatedAt
}

model WebsocketSession {
  id               String    @id @default(uuid())
  userId           String
  socketId         String
  serverId         String?
  namespace        String?
  rooms            String[]
  ipAddress        String?
  userAgent        String?
  transport        String?
  connectedAt      DateTime  @default(now())
  disconnectedAt   DateTime?
  disconnectReason String?
}

model Task {
  id            String    @id @default(uuid())
  orgId         String
  teamId        String?
  title         String
  description   String?
  status        String    @default("NEW")
  priority      String    @default("MEDIUM")
  assigneeId    String?
  createdById   String
  assignee      User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  estimatedMins Int?
  tags          String[]
  sortOrder     Int       @default(0)
  externalId    String?
  externalUrl   String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      TaskComment[]
  history       TaskHistory[]
  @@index([orgId, status])
  @@index([assigneeId])
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  actorId   String
  field     String
  oldValue  String?
  newValue  String?
  comment   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  orgId     String
  type      String   // task_assigned, task_comment, task_status
  title     String
  body      String
  isRead    Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model KnowledgeCategory {
  id          String             @id @default(uuid())
  orgId       String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  articles    KnowledgeArticle[]
}

model KnowledgeArticle {
  id          String              @id @default(uuid())
  orgId       String
  categoryId  String
  title       String
  content     String              @db.Text
  fileUrl     String?
  fileName    String?
  fileType    String?
  authorId    String
  isPinned    Boolean             @default(false)
  views       Int                 @default(0)
  isRoutine   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  category    KnowledgeCategory   @relation(fields: [categoryId], references: [id])
}

model RoutineTask {
  id          String    @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String?
  priority    String    @default("MEDIUM")
  dueTime     String?
  schedule    String    @default("DAILY")
  daysOfWeek  Int[]
  isActive    Boolean   @default(true)
  startDate   String?
  endDate     String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  org         Organisation @relation(fields: [orgId], references: [id])
  assignee    User?     @relation("RoutineAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("RoutineCreator", fields: [createdById], references: [id])

  @@index([orgId, isActive])
  @@index([assigneeId])
}



model EmployeeKpi {
  id          String   @id @default(uuid())
  orgId       String
  userId      String
  period      String   // "2026-06" — месяц
  tasksTarget Int      @default(0)
  tasksDone   Int      @default(0)
  clicksTarget Int     @default(0)
  clicksActual Int     @default(0)
  activeDaysTarget Int @default(0)
  activeDaysActual Int @default(0)
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  org         Organisation @relation(fields: [orgId], references: [id])
  user        User         @relation("KpiUser",    fields: [userId],      references: [id])
  createdBy   User         @relation("KpiCreator", fields: [createdById], references: [id])

  @@unique([orgId, userId, period])
  @@index([orgId, period])
}
