generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("TRIAL")
  trialEndsAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users        User[]
  teams        Team[]
  routineTasks RoutineTask[]
  kpis         EmployeeKpi[]
  notes        Note[]   @relation("OrgNotes")

}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  password  String
  orgId     String
  status    String    @default("ACTIVE")
  avatarUrl      String?
  telegramChatId String?
  birthDate      DateTime?
  gender         String?
  hiredAt        DateTime?
  position       String?
  phone          String?
  deletedAt      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  org       Organisation @relation(fields: [orgId], references: [id])
  userRoles    UserRole[]
  sessions     Session[]
  assignedTasks    Task[]        @relation("TaskAssignee")
  kpis             EmployeeKpi[] @relation("KpiUser")
  kpisCreated      EmployeeKpi[] @relation("KpiCreator")
  routineTasks     RoutineTask[] @relation("RoutineAssignee")
  routinesCreated  RoutineTask[] @relation("RoutineCreator")
  notes            Note[]        @relation("UserNotes")
  ownedProjects    Project[]       @relation("ProjectOwner")
  projectComments  ProjectComment[] @relation("ProjectCommentAuthor")

  // Основной отдел (для быстрых фильтров и обратной совместимости)
  primaryDepartmentId String?
  primaryDepartment   Department? @relation("PrimaryDeptMembers", fields: [primaryDepartmentId], references: [id])
  departmentLinks     DepartmentMember[]
  taskParticipations  TaskParticipant[]
  chatChannels        ChatChannelMember[]
  managedSubscribers  Subscriber[] @relation("SubscriberManager")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  permissions String[]
  userRoles   UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])
  @@unique([userId, roleId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())
  org       Organisation @relation(fields: [orgId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id     String    @id @default(uuid())
  teamId String
  userId String
  leftAt DateTime?
  team   Team @relation(fields: [teamId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  deviceName   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model ActivityEvent {
  id              String   @id @default(uuid())
  eventId         String   @unique
  batchId         String
  userId          String
  orgId           String
  eventType       String
  platform        String
  url             String?
  urlHash         String?
  pageTitle       String?
  platformData    Json?
  clientTimestamp DateTime
  serverLag       Int?
  createdAt       DateTime @default(now())
  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([orgId, eventType, createdAt])
  @@index([orgId, platform, createdAt])
}

model AnalyticsHourly {
  id           String   @id @default(uuid())
  userId       String
  orgId        String
  hourBucket   DateTime
  activeSecs   Int      @default(0)
  eventCount   Int      @default(0)
  clickCount   Int      @default(0)
  keydownCount Int      @default(0)
  scrollCount  Int      @default(0)
  pageViews    Int      @default(0)
  uniqueUrls   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, hourBucket])
  @@index([orgId, hourBucket])
}

model RealtimeStatus {
  id              String    @id @default(uuid())
  userId          String    @unique
  orgId           String
  status          String    @default("OFFLINE")
  platform        String?
  lastActivityAt  DateTime?
  lastEventType   String?
  lastUrl         String?
  lastPageTitle   String?
  todayEventCount Int       @default(0)
  wentOnlineAt    DateTime?
  wentOfflineAt   DateTime?
  updatedAt       DateTime  @updatedAt
}

model WebsocketSession {
  id               String    @id @default(uuid())
  userId           String
  socketId         String
  serverId         String?
  namespace        String?
  rooms            String[]
  ipAddress        String?
  userAgent        String?
  transport        String?
  connectedAt      DateTime  @default(now())
  disconnectedAt   DateTime?
  disconnectReason String?
}

model Task {
  id            String    @id @default(uuid())
  orgId         String
  teamId        String?
  title         String
  description   String?
  status        String    @default("NEW")
  priority      String    @default("MEDIUM")
  assigneeId    String?
  assigneeIds   String[]  @default([]) // Все исполнители задачи (включая assigneeId для обратной совместимости)
  createdById   String
  assignee      User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  estimatedMins Int?
  tags          String[]
  sortOrder     Int       @default(0)
  externalId    String?
  externalUrl   String?
  parentId      String?   // Родительская задача (для подзадач)
  productId     String?   // Привязка к карточке товара
  departmentId  String?   // Привязка к отделу
  projectId     String?   // Привязка к проекту
  dealId        String?   // Привязка к сделке CRM
  deletedAt     DateTime?
  taskTypeId    String?
  customFields  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      TaskComment[]
  history       TaskHistory[]
  checklists    TaskChecklist[]
  participants  TaskParticipant[]
  parent        Task?       @relation("SubTasks", fields: [parentId], references: [id])
  subtasks      Task[]      @relation("SubTasks")
  product       Product?    @relation(fields: [productId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  project       Project?    @relation(fields: [projectId], references: [id])
  taskType      TaskType?   @relation("TaskTypeRelation", fields: [taskTypeId], references: [id])
  fieldValues   CustomFieldValue[]
  attachments   TaskAttachment[]
  @@index([orgId, status])
  @@index([assigneeId])
  @@index([productId])
  @@index([departmentId])
  @@index([projectId])
  @@index([dealId])
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  actorId   String
  field     String
  oldValue  String?
  newValue  String?
  comment   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  orgId     String
  type      String   // task_assigned, task_comment, task_status
  title     String
  body      String
  isRead    Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model KnowledgeCategory {
  id          String             @id @default(uuid())
  orgId       String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  articles    KnowledgeArticle[]
}

model KnowledgeArticle {
  id          String              @id @default(uuid())
  orgId       String
  categoryId  String
  title       String
  content     String              @db.Text
  fileUrl     String?
  fileName    String?
  fileType    String?
  authorId    String
  isPinned    Boolean             @default(false)
  views       Int                 @default(0)
  isRoutine   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  category    KnowledgeCategory   @relation(fields: [categoryId], references: [id])
}

model RoutineTask {
  id          String    @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String?
  priority    String    @default("MEDIUM")
  dueTime     String?
  schedule    String    @default("DAILY")
  daysOfWeek  Int[]
  isActive    Boolean   @default(true)
  startDate   String?
  endDate     String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  org         Organisation @relation(fields: [orgId], references: [id])
  assignee    User?     @relation("RoutineAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("RoutineCreator", fields: [createdById], references: [id])

  @@index([orgId, isActive])
  @@index([assigneeId])
}

model EmployeeKpi {
  id          String   @id @default(uuid())
  orgId       String
  userId      String
  period      String   // "2026-06" — месяц
  tasksTarget Int      @default(0)
  tasksDone   Int      @default(0)
  clicksTarget Int     @default(0)
  clicksActual Int     @default(0)
  activeDaysTarget Int @default(0)
  activeDaysActual Int @default(0)
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  org         Organisation @relation(fields: [orgId], references: [id])
  user        User         @relation("KpiUser",    fields: [userId],      references: [id])
  createdBy   User         @relation("KpiCreator", fields: [createdById], references: [id])

  @@unique([orgId, userId, period])
  @@index([orgId, period])
}

model Note {
  id         String    @id @default(uuid())
  userId     String
  orgId      String
  title      String    @db.VarChar(255)
  content    String?   @db.Text
  status     String    @default("ACTIVE")
  priority   String    @default("MEDIUM")
  isPinned   Boolean   @default(false)
  remindAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User         @relation("UserNotes", fields: [userId], references: [id])
  org        Organisation @relation("OrgNotes",  fields: [orgId],  references: [id])
  @@index([userId, status])
  @@index([userId, isPinned])
}

model AuditLog {
  id         String    @id @default(uuid())
  orgId      String
  userId     String?
  userName   String?
  action     String    // например "login", "task.create", "employee.delete"
  category   String    // "auth", "tasks", "employees", "calls", "reviews", "settings"...
  details    String?   @db.Text // JSON строка с деталями
  ipAddress  String?
  userAgent  String?   @db.Text
  createdAt  DateTime  @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, category])
  @@index([orgId, userId])
}

model ErrorLog {
  id          String    @id @default(uuid())
  orgId       String?
  userId      String?
  endpoint    String?
  method      String?
  statusCode  Int?
  message     String    @db.Text
  stack       String?   @db.Text
  body        String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([orgId, createdAt])
  @@index([createdAt])
}

model Product {
  id          String    @id @default(uuid())
  orgId       String
  marketplace String    // "WB" или "OZON"
  articleId   String    // Артикул на маркетплейсе
  nmId        String?   // WB nmId
  name        String
  photoUrl    String?   // URL главного фото
  price       Float?
  rating      Float?
  reviewCount Int?
  stockCount  Int?
  barcode     String?
  categoryName String?
  brand       String?
  url         String?   // Ссылка на карточку на маркетплейсе
  stageId     String?   // Стадия жизненного цикла карточки
  syncedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
  stage       CardStage? @relation(fields: [stageId], references: [id])

  @@unique([orgId, marketplace, articleId])
  @@index([orgId, marketplace])
}

// ===== СПРАВОЧНИКИ =====

model Department {
  id        String    @id @default(uuid())
  orgId     String
  name      String
  color     String?   @default("#7F77DD")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tasks     Task[]
  projects  Project[]
  members   DepartmentMember[]
  primaryMembers User[] @relation("PrimaryDeptMembers")

  @@index([orgId])
  @@unique([orgId, name])
}

// Сотрудник может состоять в нескольких отделах (M2M)
model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String
  userId       String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

model CardStage {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  description String?
  color       String?   @default("#7F77DD")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([orgId])
}

// ===== ЧЕКЛИСТЫ =====

model TaskChecklist {
  id         String    @id @default(uuid())
  taskId     String
  text       String
  isDone     Boolean   @default(false)
  assigneeId String?
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ===== УЧАСТНИКИ ЗАДАЧИ =====

model TaskParticipant {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  role      String   @default("observer") // co_executor | observer | reviewer | approver
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// ===== ПРОЕКТЫ =====

model Project {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  description String?   @db.Text
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | ARCHIVED | ON_HOLD
  ownerId     String
  departmentId String?  // Обязателен на уровне API; nullable в БД для совместимости со старыми данными
  color       String?   @default("#7F77DD")
  startDate   DateTime?
  dueDate     DateTime?
  tags        String[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  department  Department?       @relation(fields: [departmentId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  comments    ProjectComment[]
  activities  ProjectActivity[]

  @@index([orgId, status])
  @@index([ownerId])
  @@index([departmentId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member") // owner | admin | member | viewer
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectComment {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User     @relation("ProjectCommentAuthor", fields: [userId], references: [id])

  @@index([projectId])
}

model ProjectActivity {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  action    String   // created | updated | member_added | task_added | status_changed | commented
  details   String?  @db.Text
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

// ===== CUSTOM FIELDS =====

model FieldGroup {
  id          String        @id @default(uuid())
  orgId       String
  name        String
  description String?
  color       String?       @default("#7F77DD")
  icon        String?
  sortOrder   Int           @default(0)
  isCollapsed Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  fields      CustomField[]

  @@index([orgId, sortOrder])
}

model CustomField {
  id             String   @id @default(uuid())
  orgId          String
  groupId        String?
  // TEXT | TEXTAREA | NUMBER | MONEY | PERCENT | DATE | DATETIME
  // SELECT | MULTISELECT | CHECKBOX | TOGGLE | USER | TEAM
  // COMPANY | COUNTERPARTY | LINK | EMAIL | PHONE | SKU | BARCODE
  // COLOR | FILE | FORMULA | AUTO_NUMBER | RATING
  type           String
  name           String
  description    String?
  isRequired     Boolean  @default(false)
  isSystem       Boolean  @default(false)
  showInTable    Boolean  @default(true)
  showInCard     Boolean  @default(true)
  showInFilter   Boolean  @default(true)
  showOnCreate   Boolean  @default(true)
  sortOrder      Int      @default(0)
  defaultValue   Json?
  config         Json?
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group            FieldGroup?          @relation(fields: [groupId], references: [id])
  projectBindings  FieldProjectBinding[]
  taskTypeBindings FieldTaskTypeBinding[]
  conditions       FieldCondition[]     @relation("ConditionSource")
  targetConditions FieldCondition[]     @relation("ConditionTarget")
  values           CustomFieldValue[]

  @@index([orgId, sortOrder])
  @@index([orgId, type])
  @@index([orgId, deletedAt])
}

model FieldProjectBinding {
  id        String @id @default(uuid())
  fieldId   String
  projectId String
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, projectId])
  @@index([projectId])
}

model TaskType {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  icon      String?
  color     String?  @default("#7F77DD")
  isDefault Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fieldBindings FieldTaskTypeBinding[]
  tasks     Task[]   @relation("TaskTypeRelation")

  @@index([orgId])
}

model FieldTaskTypeBinding {
  id         String   @id @default(uuid())
  fieldId    String
  taskTypeId String
  sortOrder  Int      @default(0)
  field      CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  taskType   TaskType    @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)

  @@unique([fieldId, taskTypeId])
  @@index([taskTypeId])
}

model FieldCondition {
  id            String @id @default(uuid())
  orgId         String
  sourceFieldId String
  operator      String  // EQ | NEQ | GT | LT | GTE | LTE | CONTAINS | IS_EMPTY | NOT_EMPTY | IN
  value         Json?
  logicGroup    Int     @default(0)
  action        String  // SHOW | HIDE | REQUIRE | UNREQUIRE | SET_VALUE | CLEAR_VALUE
  targetFieldId String
  actionValue   Json?
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())

  sourceField   CustomField @relation("ConditionSource", fields: [sourceFieldId], references: [id], onDelete: Cascade)
  targetField   CustomField @relation("ConditionTarget", fields: [targetFieldId], references: [id], onDelete: Cascade)

  @@index([orgId, sourceFieldId])
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  orgId     String
  taskId    String
  fieldId   String
  strVal    String?  @db.Text
  numVal    Float?
  boolVal   Boolean?
  dateVal   DateTime?
  jsonVal   Json?
  updatedAt DateTime @updatedAt

  task  Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  field CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([taskId, fieldId])
  @@index([orgId, fieldId, strVal])
  @@index([orgId, fieldId, numVal])
  @@index([orgId, fieldId, dateVal])
  @@index([orgId, fieldId, boolVal])
}

model SavedFilter {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  name      String
  filters   Json
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, userId])
}

model UserSidebarConfig {
  id        String   @id @default(uuid())
  userId    String   @unique
  orgId     String
  config    String   @db.Text
  sections  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String
  orgId        String
  uploadedById String
  fileName     String
  fileSize     Int
  mimeType     String
  url          String
  createdAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([orgId])
}

// ===== UNIVERSAL RELATIONS ENGINE =====

model EntityRelation {
  id           String   @id @default(uuid())
  orgId        String

  // Source entity
  sourceType   String   // TASK | PROJECT | PRODUCT | DEAL | EMPLOYEE | DOCUMENT | ORDER
  sourceId     String

  // Target entity  
  targetType   String
  targetId     String

  // Relation type
  // TASK-TASK: DEPENDS_ON | BLOCKS | WAITING_FOR | RELATED | DUPLICATE | PARENT | CHILD | CUSTOM
  // TASK-PRODUCT: LINKED
  // TASK-PROJECT: LINKED
  // etc.
  relationType String

  customLabel  String?  // for CUSTOM relation type
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, sourceType, sourceId, targetType, targetId, relationType])
  @@index([orgId, sourceType, sourceId])
  @@index([orgId, targetType, targetId])
  @@index([orgId, sourceType, sourceId, relationType])
}

// Universal Activity Log for all entities
model ActivityLog {
  id          String   @id @default(uuid())
  orgId       String
  entityType  String   // TASK | PROJECT | PRODUCT | DEAL | EMPLOYEE | CUSTOM_FIELD
  entityId    String
  actorId     String?
  actorName   String?
  action      String   // CREATED | UPDATED | DELETED | STATUS_CHANGED | ASSIGNED | LINKED | UNLINKED | COMMENTED | FILE_ADDED
  field       String?  // which field changed
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  meta        Json?    // extra data
  createdAt   DateTime @default(now())

  @@index([orgId, entityType, entityId, createdAt])
  @@index([orgId, actorId])
}

// ===== APPROVAL SYSTEM =====

// Шаблон маршрута согласования
model ApprovalFlow {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  // Триггер: MANUAL | TASK_STATUS | DEAL_STAGE | CUSTOM_FIELD
  trigger     String   @default("MANUAL")
  triggerConfig Json?  // { status: "REVIEW", fieldId: "xxx", value: "...", entityType: "TASK" }
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@index([orgId, isActive])
}

// Шаг маршрута
model ApprovalStep {
  id       String @id @default(uuid())
  flowId   String
  // Порядок шага
  order    Int
  name     String
  // Тип: SEQUENTIAL (один за другим) | PARALLEL (все одновременно) | ANY_ONE (любой один)
  type     String @default("SEQUENTIAL")
  // Кто согласует: USER | ROLE | DEPARTMENT_HEAD | MANAGER
  approverType String @default("USER")
  approverIds  Json   // [userId, ...] или ["ADMIN", "MANAGER"] для role-based
  // Дедлайн в часах (0 = без дедлайна)
  deadlineHours Int @default(0)
  // Действие при истечении: SKIP | ESCALATE | REJECT
  onTimeout String @default("SKIP")
  // Условие пропуска шага
  skipCondition Json?

  flow     ApprovalFlow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  decisions ApprovalDecision[]

  @@index([flowId, order])
}

// Запрос на согласование (конкретный экземпляр)
model ApprovalRequest {
  id         String   @id @default(uuid())
  orgId      String
  flowId     String
  // Что согласуем
  entityType String   // TASK | DEAL | DOCUMENT | CUSTOM
  entityId   String
  entityTitle String
  // Инициатор
  requestedById String
  requestedByName String
  // Текущий шаг (индекс)
  currentStep Int     @default(0)
  // Статус: PENDING | APPROVED | REJECTED | CANCELLED | EXPIRED
  status     String   @default("PENDING")
  comment    String?  // комментарий при финальном решении
  completedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  flow      ApprovalFlow      @relation(fields: [flowId], references: [id])
  decisions ApprovalDecision[]

  @@index([orgId, status])
  @@index([orgId, entityType, entityId])
  @@index([orgId, requestedById])
}

// Решение по шагу
model ApprovalDecision {
  id         String   @id @default(uuid())
  requestId  String
  stepId     String
  approverId String
  approverName String
  // PENDING | APPROVED | REJECTED | SKIPPED
  status     String   @default("PENDING")
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step    ApprovalStep    @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([requestId, stepId, approverId])
  @@index([requestId])
  @@index([approverId, status])
}

// ===== CHAT / МЕССЕНДЖЕР =====

model ChatChannel {
  id           String   @id @default(uuid())
  orgId        String
  type         String   // DIRECT | GROUP
  name         String?  // только для GROUP; для DIRECT вычисляется на фронте
  avatarUrl    String?
  departmentId String?  // опциональная привязка группового канала к отделу
  projectId    String?  // опциональная привязка группового канала к проекту
  pinnedMessageId String? // закреплённое сообщение (без FK — просто ссылка на id)
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members  ChatChannelMember[]
  messages ChatMessage[]

  @@index([orgId, type])
  @@index([departmentId])
  @@index([projectId])
}

model ChatChannelMember {
  id         String    @id @default(uuid())
  channelId  String
  userId     String
  role       String    @default("member") // owner | member (для групп)
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

model ChatMessage {
  id             String    @id @default(uuid())
  channelId      String
  senderId       String
  content        String?   @db.Text
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?   // image | file | audio
  replyToId      String?   // ссылка на id другого сообщения (без FK, разрешается вручную)
  mentionedIds   String[]  @default([]) // userId сотрудников, упомянутых через @Имя
  reactions      Json?     // { "👍": ["userId1","userId2"], "❤️": ["userId3"] }
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([senderId])
}


// ===== CRM ПОДПИСЧИКОВ (KingStats и аналоги) — Этап 1 =====

model Subscriber {
  id                 String    @id @default(uuid())
  orgId              String

  // Данные из внешней системы
  externalId         String?
  externalSource     String?   @default("kingstats")
  username           String?
  firstName          String?
  lastName           String?
  email              String?
  phone              String?
  externalRole       String?   // роль в внешней системе (admin/user)

  // Подписка
  plan               String?   // TRIAL | PRO | BUSINESS | NONE
  planStatus         String?   // active | expired | none
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  registeredAt       DateTime?
  lastLoginAt        DateTime?

  // CRM-поля
  crmStatus          String    @default("NEW") // NEW | IN_PROGRESS | CONTACTED | RENEWED | LOST | ARCHIVED
  tags               String[]  @default([])
  managerId          String?
  notes              String?   @db.Text

  lastSyncAt         DateTime?
  deletedAt          DateTime? // корзина (Этап 11), пока не используется активно
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  manager            User?     @relation("SubscriberManager", fields: [managerId], references: [id])
  history            SubscriberHistory[]
  comments           SubscriberComment[]
  communications     SubscriberCommunication[]

  @@unique([orgId, externalSource, externalId])
  @@index([orgId])
  @@index([crmStatus])
  @@index([plan])
  @@index([managerId])
  @@index([trialEndsAt])
  @@index([subscriptionEndsAt])
}

// История изменений подписчика (тариф/статус/теги/менеджер) — задел под Этап 2
model SubscriberHistory {
  id           String   @id @default(uuid())
  subscriberId String
  orgId        String
  field        String   // plan | planStatus | crmStatus | tags | managerId
  oldValue     String?
  newValue     String?
  changedById  String?  // null, если изменение системное (авто-синк)
  createdAt    DateTime @default(now())

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@index([orgId])
}

// ===== ЭТАП 3: КОММУНИКАЦИИ (Email/WhatsApp/Telegram/Телефон) =====

model MessageTemplate {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  channel   String   // EMAIL | WHATSAPP | TELEGRAM | SMS
  subject   String?  // только для EMAIL
  content   String   @db.Text // поддерживает {firstName}, {plan}, {trialEndsAt} и т.д.
  createdById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, channel])
}

model SubscriberCommunication {
  id           String   @id @default(uuid())
  subscriberId String
  orgId        String
  channel      String   // EMAIL | WHATSAPP | TELEGRAM | PHONE
  direction    String   @default("OUTGOING") // OUTGOING | INCOMING (задел на будущее)
  content      String?  @db.Text
  templateId   String?
  sentById     String?
  createdAt    DateTime @default(now())

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@index([orgId])
}

// ===== ЭТАП 4: АВТОМАТИЗАЦИЯ =====

model SubscriberAutomationRule {
  id               String   @id @default(uuid())
  orgId            String
  name             String
  triggerType      String   // ON_REGISTER | DAYS_REMAINING | SUBSCRIPTION_EXPIRED | PLAN_PURCHASED | PLAN_CHANGED | INACTIVE_DAYS | TAG_ADDED | STATUS_CHANGED | MANAGER_ASSIGNED
  triggerDateField String?  // trialEndsAt | subscriptionEndsAt — для DAYS_REMAINING
  triggerDays      Int?     // число дней — для DAYS_REMAINING / INACTIVE_DAYS
  triggerTag       String?  // конкретный тег — для TAG_ADDED
  triggerStatus    String?  // конкретный статус — для STATUS_CHANGED (опционально)
  conditions       Json?    // доп. условия [{field, operator, value}] — задел на будущее
  actions          Json     // [{ type, params }]
  isActive         Boolean  @default(true)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orgId, triggerType])
}

model SubscriberAutomationLog {
  id           String   @id @default(uuid())
  orgId        String
  ruleId       String
  subscriberId String
  status       String   // SUCCESS | ERROR | SKIPPED
  message      String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([orgId, subscriberId])
  @@index([ruleId])
}

model SubscriberComment {
  id           String   @id @default(uuid())
  subscriberId String
  orgId        String
  authorId     String
  content      String   @db.Text
  createdAt    DateTime @default(now())

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@index([orgId])
}

model SubscriberIntegration {
  id           String    @id @default(uuid())
  orgId        String
  name         String    // 'kingstats'
  displayName  String?
  apiUrl       String?
  apiKey       String?
  isActive     Boolean   @default(false)
  lastSyncAt   DateTime?
  lastSyncStatus String? // SUCCESS | ERROR
  lastSyncMessage String? @db.Text
  totalFetched Int       @default(0)
  totalCreated Int       @default(0)
  totalUpdated Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([orgId, name])
}
