generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("TRIAL")
  trialEndsAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users        User[]
  teams        Team[]
  routineTasks RoutineTask[]
  kpis         EmployeeKpi[]
  notes        Note[]   @relation("OrgNotes")

}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  password  String
  orgId     String
  status    String    @default("ACTIVE")
  avatarUrl      String?
  telegramChatId String?
  birthDate      DateTime?
  gender         String?   // MALE | FEMALE
  hiredAt        DateTime?
  position       String?
  phone          String?
  deletedAt      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  org       Organisation @relation(fields: [orgId], references: [id])
  userRoles    UserRole[]
  sessions     Session[]
  assignedTasks    Task[]        @relation("TaskAssignee")
  kpis             EmployeeKpi[] @relation("KpiUser")
  kpisCreated      EmployeeKpi[] @relation("KpiCreator")
  routineTasks     RoutineTask[] @relation("RoutineAssignee")
  routinesCreated  RoutineTask[] @relation("RoutineCreator")
  notes            Note[]        @relation("UserNotes")
  ownedProjects    Project[]       @relation("ProjectOwner")
  projectComments  ProjectComment[] @relation("ProjectCommentAuthor")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  permissions String[]
  userRoles   UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])
  @@unique([userId, roleId])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())
  org       Organisation @relation(fields: [orgId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id     String    @id @default(uuid())
  teamId String
  userId String
  leftAt DateTime?
  team   Team @relation(fields: [teamId], references: [id])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  deviceName   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model ActivityEvent {
  id              String   @id @default(uuid())
  eventId         String   @unique
  batchId         String
  userId          String
  orgId           String
  eventType       String
  platform        String
  url             String?
  urlHash         String?
  pageTitle       String?
  platformData    Json?
  clientTimestamp DateTime
  serverLag       Int?
  createdAt       DateTime @default(now())
  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@index([orgId, eventType, createdAt])
  @@index([orgId, platform, createdAt])
}

model AnalyticsHourly {
  id           String   @id @default(uuid())
  userId       String
  orgId        String
  hourBucket   DateTime
  activeSecs   Int      @default(0)
  eventCount   Int      @default(0)
  clickCount   Int      @default(0)
  keydownCount Int      @default(0)
  scrollCount  Int      @default(0)
  pageViews    Int      @default(0)
  uniqueUrls   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, hourBucket])
  @@index([orgId, hourBucket])
}

model RealtimeStatus {
  id              String    @id @default(uuid())
  userId          String    @unique
  orgId           String
  status          String    @default("OFFLINE")
  platform        String?
  lastActivityAt  DateTime?
  lastEventType   String?
  lastUrl         String?
  lastPageTitle   String?
  todayEventCount Int       @default(0)
  wentOnlineAt    DateTime?
  wentOfflineAt   DateTime?
  updatedAt       DateTime  @updatedAt
}

model WebsocketSession {
  id               String    @id @default(uuid())
  userId           String
  socketId         String
  serverId         String?
  namespace        String?
  rooms            String[]
  ipAddress        String?
  userAgent        String?
  transport        String?
  connectedAt      DateTime  @default(now())
  disconnectedAt   DateTime?
  disconnectReason String?
}

model Task {
  id            String    @id @default(uuid())
  orgId         String
  teamId        String?
  title         String
  description   String?
  status        String    @default("NEW")
  priority      String    @default("MEDIUM")
  assigneeId    String?
  createdById   String
  assignee      User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  estimatedMins Int?
  tags          String[]
  sortOrder     Int       @default(0)
  externalId    String?
  externalUrl   String?
  parentId      String?   // Родительская задача (для подзадач)
  productId     String?   // Привязка к карточке товара
  departmentId  String?   // Привязка к отделу
  projectId     String?   // Привязка к проекту
  dealId        String?   // Привязка к сделке CRM
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      TaskComment[]
  history       TaskHistory[]
  checklists    TaskChecklist[]
  participants  TaskParticipant[]
  parent        Task?       @relation("SubTasks", fields: [parentId], references: [id])
  subtasks      Task[]      @relation("SubTasks")
  product       Product?    @relation(fields: [productId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  project       Project?    @relation(fields: [projectId], references: [id])
  deal          CrmDeal?    @relation(fields: [dealId], references: [id])
  @@index([orgId, status])
  @@index([assigneeId])
  @@index([productId])
  @@index([departmentId])
  @@index([projectId])
  @@index([dealId])
}

model TaskComment {
  id        String    @id @default(uuid())
  taskId    String
  authorId  String
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id])
}

model TaskHistory {
  id        String   @id @default(uuid())
  taskId    String
  actorId   String
  field     String
  oldValue  String?
  newValue  String?
  comment   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  orgId     String
  type      String   // task_assigned, task_comment, task_status
  title     String
  body      String
  isRead    Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model KnowledgeCategory {
  id          String             @id @default(uuid())
  orgId       String
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  articles    KnowledgeArticle[]
}

model KnowledgeArticle {
  id          String              @id @default(uuid())
  orgId       String
  categoryId  String
  title       String
  content     String              @db.Text
  fileUrl     String?
  fileName    String?
  fileType    String?
  authorId    String
  isPinned    Boolean             @default(false)
  views       Int                 @default(0)
  isRoutine   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  category    KnowledgeCategory   @relation(fields: [categoryId], references: [id])
}

model RoutineTask {
  id          String    @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String?
  priority    String    @default("MEDIUM")
  dueTime     String?
  schedule    String    @default("DAILY")
  daysOfWeek  Int[]
  isActive    Boolean   @default(true)
  startDate   String?
  endDate     String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  org         Organisation @relation(fields: [orgId], references: [id])
  assignee    User?     @relation("RoutineAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("RoutineCreator", fields: [createdById], references: [id])

  @@index([orgId, isActive])
  @@index([assigneeId])
}



model EmployeeKpi {
  id          String   @id @default(uuid())
  orgId       String
  userId      String
  period      String   // "2026-06" — месяц
  tasksTarget Int      @default(0)
  tasksDone   Int      @default(0)
  clicksTarget Int     @default(0)
  clicksActual Int     @default(0)
  activeDaysTarget Int @default(0)
  activeDaysActual Int @default(0)
  notes       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  org         Organisation @relation(fields: [orgId], references: [id])
  user        User         @relation("KpiUser",    fields: [userId],      references: [id])
  createdBy   User         @relation("KpiCreator", fields: [createdById], references: [id])

  @@unique([orgId, userId, period])
  @@index([orgId, period])
}

model Note {
  id         String    @id @default(uuid())
  userId     String
  orgId      String
  title      String    @db.VarChar(255)
  content    String?   @db.Text
  status     String    @default("ACTIVE")
  priority   String    @default("MEDIUM")
  isPinned   Boolean   @default(false)
  remindAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User         @relation("UserNotes", fields: [userId], references: [id])
  org        Organisation @relation("OrgNotes",  fields: [orgId],  references: [id])
  @@index([userId, status])
  @@index([userId, isPinned])
}

model AuditLog {
  id         String    @id @default(uuid())
  orgId      String
  userId     String?
  userName   String?
  action     String    // например "login", "task.create", "employee.delete"
  category   String    // "auth", "tasks", "employees", "calls", "reviews", "settings"...
  details    String?   @db.Text // JSON строка с деталями
  ipAddress  String?
  userAgent  String?   @db.Text
  createdAt  DateTime  @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, category])
  @@index([orgId, userId])
}

model ErrorLog {
  id          String    @id @default(uuid())
  orgId       String?
  userId      String?
  endpoint    String?
  method      String?
  statusCode  Int?
  message     String    @db.Text
  stack       String?   @db.Text
  body        String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([orgId, createdAt])
  @@index([createdAt])
}

model Product {
  id          String    @id @default(uuid())
  orgId       String
  marketplace String    // "WB" или "OZON"
  articleId   String    // Артикул на маркетплейсе
  nmId        String?   // WB nmId
  name        String
  photoUrl    String?   // URL главного фото
  price       Float?
  rating      Float?
  reviewCount Int?
  stockCount  Int?
  barcode     String?
  categoryName String?
  brand       String?
  url         String?   // Ссылка на карточку на маркетплейсе
  stageId     String?   // Стадия жизненного цикла карточки
  syncedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
  stage       CardStage? @relation(fields: [stageId], references: [id])

  @@unique([orgId, marketplace, articleId])
  @@index([orgId, marketplace])
}

// ===== СПРАВОЧНИКИ =====

model Department {
  id        String    @id @default(uuid())
  orgId     String
  name      String
  color     String?   @default("#7F77DD")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tasks     Task[]

  @@index([orgId])
  @@unique([orgId, name])
}

model CardStage {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  description String?
  color       String?   @default("#7F77DD")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([orgId])
}

// ===== ЧЕКЛИСТЫ =====

model TaskChecklist {
  id         String    @id @default(uuid())
  taskId     String
  text       String
  isDone     Boolean   @default(false)
  assigneeId String?
  position   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ===== УЧАСТНИКИ ЗАДАЧИ =====

model TaskParticipant {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  role      String   @default("observer") // co_executor | observer
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// ===== ПРОЕКТЫ =====

model Project {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  description String?   @db.Text
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | ARCHIVED | ON_HOLD
  ownerId     String
  color       String?   @default("#7F77DD")
  startDate   DateTime?
  dueDate     DateTime?
  tags        String[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner       User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  comments    ProjectComment[]
  activities  ProjectActivity[]

  @@index([orgId, status])
  @@index([ownerId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member") // owner | admin | member | viewer
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectComment {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    User     @relation("ProjectCommentAuthor", fields: [userId], references: [id])

  @@index([projectId])
}

model ProjectActivity {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  action    String   // created | updated | member_added | task_added | status_changed | commented
  details   String?  @db.Text
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

// ===== CRM =====

model CrmContact {
  id        String   @id @default(uuid())
  orgId     String
  firstName String
  lastName  String?
  email     String?
  phone     String?
  position  String?
  companyId String?
  tags      String[]
  source    String?
  ownerId   String?
  notes     String?  @db.Text
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   CrmCompany? @relation(fields: [companyId], references: [id])
  deals     CrmDeal[]
  activities CrmActivity[]

  @@index([orgId])
  @@index([companyId])
}

model CrmCompany {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  industry  String?
  website   String?
  phone     String?
  email     String?
  address   String?
  tags      String[]
  ownerId   String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts  CrmContact[]
  deals     CrmDeal[]
  activities CrmActivity[]

  @@index([orgId])
}

model CrmDeal {
  id          String    @id @default(uuid())
  orgId       String
  title       String
  amount      Float?
  currency    String    @default("RUB")
  stage       String    @default("NEW") // NEW | QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
  probability Int?      @default(0)
  contactId   String?
  companyId   String?
  ownerId     String?
  source      String?
  closedAt    DateTime?
  lostReason  String?
  tags        String[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contact    CrmContact?  @relation(fields: [contactId], references: [id])
  company    CrmCompany?  @relation(fields: [companyId], references: [id])
  activities CrmActivity[]
  tasks      Task[]

  @@index([orgId, stage])
  @@index([ownerId])
}

model CrmLead {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  email     String?
  phone     String?
  source    String?
  status    String   @default("NEW") // NEW | IN_PROGRESS | CONVERTED | LOST
  ownerId   String?
  notes     String?  @db.Text
  tags      String[]
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities CrmActivity[]

  @@index([orgId, status])
}

model CrmActivity {
  id        String   @id @default(uuid())
  orgId     String
  type      String   // call | email | meeting | note | task | status_change | deal_created
  content   String?  @db.Text
  userId    String?
  contactId String?
  companyId String?
  dealId    String?
  leadId    String?
  createdAt DateTime @default(now())

  contact   CrmContact?  @relation(fields: [contactId], references: [id])
  company   CrmCompany?  @relation(fields: [companyId], references: [id])
  deal      CrmDeal?     @relation(fields: [dealId], references: [id])
  lead      CrmLead?     @relation(fields: [leadId], references: [id])

  @@index([orgId, createdAt])
  @@index([contactId])
  @@index([dealId])
}

model UserSidebarConfig {
  id        String   @id @default(uuid())
  userId    String   @unique
  orgId     String
  config    String   @db.Text // JSON строка с группами и разделами
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orgId])
}
